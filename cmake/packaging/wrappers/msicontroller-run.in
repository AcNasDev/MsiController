#!/bin/sh
set -eu

APP_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"

export LD_LIBRARY_PATH="${APP_DIR}/lib:${APP_DIR}/qt/lib${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"
export QT_PLUGIN_PATH="${APP_DIR}/qt/plugins${QT_PLUGIN_PATH:+:${QT_PLUGIN_PATH}}"
export QML_IMPORT_PATH="${APP_DIR}/qt/qml${QML_IMPORT_PATH:+:${QML_IMPORT_PATH}}"
export QML2_IMPORT_PATH="${APP_DIR}/qt/qml${QML2_IMPORT_PATH:+:${QML2_IMPORT_PATH}}"

exec "${APP_DIR}/bin/@MSICONTROLLER_WRAPPED_BINARY@" "$@"
