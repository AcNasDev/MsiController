PACKAGE_NAME="@MSICONTROLLER_DKMS_MODULE_NAME@"
PACKAGE_VERSION="@MSICONTROLLER_DKMS_VERSION@"
BUILT_MODULE_NAME[0]="@MSICONTROLLER_DKMS_MODULE_NAME@"
BUILT_MODULE_LOCATION[0]="."
DEST_MODULE_LOCATION[0]="/updates/dkms"
AUTOINSTALL="yes"
REMAKE_INITRD="no"
MAKE[0]="make KERNELRELEASE=${kernelver}"
CLEAN="make clean KERNELRELEASE=${kernelver}"
