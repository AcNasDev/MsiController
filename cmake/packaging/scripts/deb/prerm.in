#!/bin/sh
set -e
cd /

DKMS_NAME="@MSICONTROLLER_DKMS_MODULE_NAME@"
DKMS_VERSION="@MSICONTROLLER_DKMS_VERSION@"
SERVICE_NAME="msi-ec-service.service"

case "$1" in
    remove|deconfigure)
        if command -v systemctl >/dev/null 2>&1; then
            systemctl stop "$SERVICE_NAME" >/dev/null 2>&1 || true
            systemctl disable "$SERVICE_NAME" >/dev/null 2>&1 || true
        fi

        modprobe -r "$DKMS_NAME" >/dev/null 2>&1 || true

        if command -v dkms >/dev/null 2>&1; then
            dkms remove -m "$DKMS_NAME" -v "$DKMS_VERSION" --all >/dev/null 2>&1 || true
        fi
        ;;
esac

exit 0
